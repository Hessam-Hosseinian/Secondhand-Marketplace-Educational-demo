<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.CreateEditAdController" styleClass="page">
 <top><HBox alignment="CENTER_LEFT" styleClass="app-header"><Button text="Cancel" onAction="#cancel" styleClass="ghost-button"/><Region HBox.hgrow="ALWAYS"/><HBox alignment="CENTER_LEFT" spacing="0"><Label text="Re:Market" styleClass="wordmark"/><Label text="." styleClass="wordmark-dot"/></HBox></HBox></top>
 <center><ScrollPane fitToWidth="true"><VBox alignment="TOP_CENTER" styleClass="page-content">
  <VBox maxWidth="840" spacing="13" styleClass="surface">
   <Label fx:id="headingLabel" text="Create a listing" styleClass="page-title"/><Label text="Clear details and good photos help your item sell faster. New listings are reviewed before publishing." maxWidth="780" wrapText="true" styleClass="muted"/>
   <Label text="Title *" styleClass="field-label"/><TextField fx:id="titleField" promptText="What are you selling?"/>
   <Label text="Description *" styleClass="field-label"/><TextArea fx:id="descriptionArea" promptText="Describe condition, age, and what is included" prefRowCount="5" wrapText="true"/>
   <HBox spacing="12"><VBox spacing="6" HBox.hgrow="ALWAYS"><Label text="Price (IRR) *" styleClass="field-label"/><TextField fx:id="priceField" promptText="0"/></VBox><VBox spacing="6" HBox.hgrow="ALWAYS"><Label text="Condition *" styleClass="field-label"/><ComboBox fx:id="conditionBox" maxWidth="Infinity"/></VBox></HBox>
   <HBox spacing="12"><VBox spacing="6" HBox.hgrow="ALWAYS"><Label text="Category *" styleClass="field-label"/><ComboBox fx:id="mainCategoryBox" onAction="#mainChanged" maxWidth="Infinity"/></VBox><VBox spacing="6" HBox.hgrow="ALWAYS"><Label text="Subcategory *" styleClass="field-label"/><ComboBox fx:id="subcategoryBox" onAction="#subcategoryChanged" maxWidth="Infinity"/></VBox><VBox spacing="6" HBox.hgrow="ALWAYS"><Label text="City *" styleClass="field-label"/><ComboBox fx:id="cityBox" maxWidth="Infinity"/></VBox></HBox>
   <VBox fx:id="dynamicAttributesBox" spacing="10" styleClass="attribute-grid"/>
   <HBox><VBox spacing="5"><Label text="Photos" styleClass="field-label"/><Label text="Select one or more JPG, PNG, WEBP, or GIF images." styleClass="muted"/></VBox><Region HBox.hgrow="ALWAYS"/><Button text="Add photos" onAction="#chooseImages" styleClass="secondary-button"/></HBox>
   <ListView fx:id="imageList" prefHeight="100"/>
   <Label text="Additional details" styleClass="field-label"/><TextArea fx:id="attributesArea" promptText="Color, dimensions, accessories, or anything else buyers should know" prefRowCount="3" wrapText="true"/>
   <Label fx:id="errorLabel" styleClass="error-text"/><HBox alignment="CENTER_RIGHT" spacing="10"><Button text="Cancel" onAction="#cancel" styleClass="secondary-button"/><Button text="Submit for review" onAction="#submit" styleClass="primary-button"/></HBox>
  </VBox>
 </VBox></ScrollPane></center>
</BorderPane>
