<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.CreateEditAdController" styleClass="page">
 <top><HBox alignment="CENTER_LEFT" spacing="10" styleClass="app-header"><Button text="←  My listings" onAction="#cancel" styleClass="ghost-button"/><Region HBox.hgrow="ALWAYS"/><HBox alignment="CENTER_LEFT" spacing="8"><Label text="R" styleClass="brand-mark-small"/><HBox alignment="CENTER_LEFT" spacing="0"><Label text="Re:Market" styleClass="wordmark"/><Label text="." styleClass="wordmark-dot"/></HBox></HBox><Region HBox.hgrow="ALWAYS"/><Label text="LISTING EDITOR" styleClass="listing-editor-badge"/></HBox></top>
 <center><StackPane>
  <ScrollPane fx:id="formScroll" fitToWidth="true"><VBox alignment="TOP_CENTER" spacing="18" styleClass="listing-page-content">
   <HBox maxWidth="1120" alignment="CENTER_LEFT" spacing="16" styleClass="listing-intro"><VBox spacing="4"><Label fx:id="headingLabel" text="Create a great listing" styleClass="listing-page-title"/><Label fx:id="formSubtitleLabel" text="Good details and honest photos help the right buyer find your item." wrapText="true" styleClass="muted"/></VBox><Region HBox.hgrow="ALWAYS"/><HBox alignment="CENTER" spacing="7" styleClass="listing-steps"><Label text="1" styleClass="step-number-active"/><Label text="Details" styleClass="step-label"/><Label text="—" styleClass="step-divider"/><Label text="2" styleClass="step-number"/><Label text="Photos" styleClass="step-label"/><Label text="—" styleClass="step-divider"/><Label text="3" styleClass="step-number"/><Label text="Review" styleClass="step-label"/></HBox></HBox>
   <HBox maxWidth="1120" alignment="TOP_CENTER" spacing="20">
    <VBox HBox.hgrow="ALWAYS" spacing="16">
     <VBox spacing="13" styleClass="listing-section"><HBox alignment="CENTER_LEFT"><Label text="1" styleClass="section-number"/><VBox spacing="2"><Label text="Tell buyers what you’re selling" styleClass="listing-section-title"/><Label text="Use a specific title and describe the real condition." styleClass="admin-row-meta"/></VBox></HBox><Separator/>
      <HBox alignment="CENTER_LEFT"><Label text="Listing title  *" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="titleCountLabel" text="0 / 255" styleClass="field-counter"/></HBox><TextField fx:id="titleField" promptText="e.g. Sony WH-1000XM5 headphones"/>
      <HBox alignment="CENTER_LEFT"><Label text="Description  *" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="descriptionCountLabel" text="0 / 5000" styleClass="field-counter"/></HBox><TextArea fx:id="descriptionArea" promptText="Mention age, condition, included accessories, and any known flaws…" prefRowCount="5" wrapText="true"/>
      <HBox spacing="11"><VBox HBox.hgrow="ALWAYS" spacing="6"><Label text="Main category  *" styleClass="field-label"/><ComboBox fx:id="mainCategoryBox" onAction="#mainChanged" maxWidth="Infinity"/></VBox><VBox HBox.hgrow="ALWAYS" spacing="6"><Label text="Subcategory  *" styleClass="field-label"/><ComboBox fx:id="subcategoryBox" onAction="#subcategoryChanged" maxWidth="Infinity"/></VBox></HBox>
      <HBox spacing="11"><VBox HBox.hgrow="ALWAYS" spacing="6"><Label text="Price (IRR)  *" styleClass="field-label"/><TextField fx:id="priceField" promptText="Enter your asking price"/></VBox><VBox HBox.hgrow="ALWAYS" spacing="6"><Label text="Condition  *" styleClass="field-label"/><ComboBox fx:id="conditionBox" maxWidth="Infinity"/></VBox><VBox HBox.hgrow="ALWAYS" spacing="6"><Label text="Pickup city  *" styleClass="field-label"/><ComboBox fx:id="cityBox" maxWidth="Infinity"/></VBox></HBox>
      <VBox fx:id="dynamicAttributesBox" spacing="10" visible="false" managed="false" styleClass="listing-specifications"/>
     </VBox>
     <VBox spacing="13" styleClass="listing-section"><HBox alignment="CENTER_LEFT"><Label text="2" styleClass="section-number"/><VBox spacing="2"><Label text="Add clear photos" styleClass="listing-section-title"/><Label text="The first image becomes the cover. You can add up to 10 photos." styleClass="admin-row-meta"/></VBox><Region HBox.hgrow="ALWAYS"/><ProgressIndicator fx:id="imageUploadIndicator" prefWidth="22" prefHeight="22" visible="false" managed="false"/><Label fx:id="imageCountLabel" text="0 / 10 photos" styleClass="photo-count-label"/></HBox><Separator/>
      <HBox alignment="CENTER_LEFT" spacing="10" styleClass="photo-upload-zone"><VBox spacing="3"><Label text="Show the item from several angles" styleClass="field-label"/><Label text="JPG, PNG, WEBP or GIF · maximum 10 files" styleClass="admin-row-meta"/></VBox><Region HBox.hgrow="ALWAYS"/><Button fx:id="uploadButton" text="＋  Choose photos" onAction="#chooseImages" styleClass="secondary-button"/></HBox>
      <Label fx:id="photoEmptyLabel" text="No photos yet — listings with useful photos usually get more attention." wrapText="true" styleClass="photo-empty-state"/>
      <ListView fx:id="imageList" prefHeight="155" minHeight="155" styleClass="photo-preview-list"/>
      <HBox alignment="CENTER_RIGHT"><Button fx:id="removeImageButton" text="Remove selected" onAction="#removeImage" disable="true" styleClass="ghost-button"/></HBox>
     </VBox>
     <VBox spacing="11" styleClass="listing-section"><HBox alignment="CENTER_LEFT"><Label text="3" styleClass="section-number"/><VBox spacing="2"><Label text="Anything else buyers should know?" styleClass="listing-section-title"/><Label text="Optional details can reduce repetitive questions." styleClass="admin-row-meta"/></VBox></HBox><Separator/><TextArea fx:id="attributesArea" promptText="Color, dimensions, accessories, pickup notes, warranty…" prefRowCount="3" wrapText="true"/></VBox>
     <VBox spacing="9" styleClass="listing-submit-panel"><Label fx:id="errorLabel" visible="false" managed="false" wrapText="true" styleClass="error-text"/><HBox alignment="CENTER_LEFT" spacing="10"><VBox spacing="2"><Label text="Ready to publish?" styleClass="field-label"/><Label fx:id="saveStatusLabel" text="Your listing will be reviewed before it goes live." styleClass="admin-row-meta"/></VBox><Region HBox.hgrow="ALWAYS"/><Button text="Cancel" onAction="#cancel" styleClass="ghost-button"/><Button fx:id="submitButton" text="Submit for review" onAction="#submit" styleClass="primary-button"/></HBox></VBox>
    </VBox>
    <VBox prefWidth="280" spacing="14">
     <VBox spacing="12" styleClass="listing-side-card"><Label text="A strong listing includes" styleClass="listing-side-title"/><Label text="✓  A specific, searchable title" styleClass="checklist-item"/><Label text="✓  An honest condition description" styleClass="checklist-item"/><Label text="✓  Clear photos in good lighting" styleClass="checklist-item"/><Label text="✓  A realistic asking price" styleClass="checklist-item"/><Label text="✓  Pickup details for the buyer" styleClass="checklist-item"/></VBox>
     <VBox spacing="9" styleClass="listing-side-card, review-side-card"><Label text="◎  How review works" styleClass="listing-side-title"/><Label text="An admin checks that the listing is complete and follows marketplace guidelines. You’ll see the result in My listings." wrapText="true" styleClass="admin-row-meta"/></VBox>
     <VBox spacing="7" styleClass="listing-safety-card"><Label text="Safety first" styleClass="field-label"/><Label text="Never include passwords, payment details, or private documents in your listing or photos." wrapText="true" styleClass="admin-row-meta"/></VBox>
    </VBox>
   </HBox>
  </VBox></ScrollPane>
  <VBox fx:id="formLoading" alignment="CENTER" spacing="11" styleClass="form-loading"><ProgressIndicator prefWidth="44" prefHeight="44"/><Label text="Preparing the listing editor…" styleClass="muted"/></VBox>
 </StackPane></center>
</BorderPane>
