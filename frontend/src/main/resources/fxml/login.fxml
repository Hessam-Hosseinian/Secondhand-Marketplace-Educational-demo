<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.LoginController" styleClass="auth-background">
 <children>
  <HBox maxWidth="920" maxHeight="590" styleClass="auth-shell">
   <VBox prefWidth="430" spacing="20" styleClass="auth-hero">
    <padding><Insets top="54" right="44" bottom="54" left="44"/></padding>
    <Label text="SECONDHAND" styleClass="eyebrow"/>
    <Label text="Good things deserve a second story." wrapText="true" styleClass="hero-title"/>
    <Label text="Discover useful finds nearby, talk directly with sellers, and give quality items a new home." wrapText="true" styleClass="hero-copy"/>
    <Region VBox.vgrow="ALWAYS"/>
    <Label text="●  Secure accounts    ●  Reviewed listings" styleClass="hero-note"/>
   </VBox>
   <VBox prefWidth="490" spacing="16" styleClass="auth-form">
    <padding><Insets top="64" right="56" bottom="52" left="56"/></padding>
    <Label text="Welcome back" styleClass="page-title"/>
    <Label text="Sign in to continue to your marketplace." styleClass="muted"/>
    <Region prefHeight="12"/>
    <Label text="Username" styleClass="field-label"/><TextField fx:id="usernameField" promptText="e.g. buyer1"/>
    <Label text="Password" styleClass="field-label"/><PasswordField fx:id="passwordField" promptText="Your password" onAction="#login"/>
    <Label fx:id="errorLabel" styleClass="error-text" wrapText="true"/>
    <Button text="Sign in" onAction="#login" maxWidth="Infinity" styleClass="primary-button"/>
    <HBox alignment="CENTER" spacing="6"><Label text="New here?" styleClass="muted"/><Button text="Create an account" onAction="#register" styleClass="link-button"/></HBox>
   </VBox>
  </HBox>
 </children>
</StackPane>
