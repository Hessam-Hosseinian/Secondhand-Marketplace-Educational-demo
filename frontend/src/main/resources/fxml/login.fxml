<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.LoginController" styleClass="auth-background">
 <HBox prefWidth="850" maxWidth="850" prefHeight="540" maxHeight="540" styleClass="auth-shell">
  <VBox prefWidth="370" maxWidth="370" spacing="18" styleClass="auth-brand">
   <Label text="RE:MARKET" styleClass="eyebrow"/>
   <Label text="Good things deserve another chapter." wrapText="true" maxWidth="280" styleClass="auth-brand-title"/>
   <Label text="Buy thoughtfully, sell simply, and connect directly with people in your community." wrapText="true" maxWidth="280" styleClass="auth-brand-copy"/>
   <Region VBox.vgrow="ALWAYS"/>
   <Button text="Browse as guest" onAction="#browse" styleClass="ghost-light-button"/>
  </VBox>
  <VBox prefWidth="480" maxWidth="480" spacing="14" styleClass="auth-form">
   <Label text="Welcome back" styleClass="auth-title"/>
   <Label text="Sign in to manage listings, messages, and saved items." wrapText="true" styleClass="muted"/>
   <Region prefHeight="12"/>
   <Label text="Username" styleClass="field-label"/><TextField fx:id="usernameField" promptText="Enter your username"/>
   <Label text="Password" styleClass="field-label"/><PasswordField fx:id="passwordField" promptText="Enter your password" onAction="#login"/>
   <Label fx:id="errorLabel" styleClass="error-text" wrapText="true"/>
   <Button text="Sign in" onAction="#login" maxWidth="Infinity" styleClass="primary-button"/>
   <HBox alignment="CENTER" spacing="6"><Label text="New to Re:Market?" styleClass="muted"/><Button text="Create account" onAction="#register" styleClass="link-button"/></HBox>
  </VBox>
 </HBox>
</StackPane>
