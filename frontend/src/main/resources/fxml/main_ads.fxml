<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.MainAdsController" styleClass="page">
 <top><VBox>
  <HBox alignment="CENTER_LEFT" spacing="8" styleClass="app-header">
   <Label text="RE:MARKET" styleClass="wordmark"/><Region HBox.hgrow="ALWAYS"/>
   <Button text="Sell an item" onAction="#create" styleClass="primary-button"/>
   <Button fx:id="myAdsButton" text="My listings" onAction="#myAds" styleClass="nav-button"/>
   <Button fx:id="favoritesButton" text="Saved" onAction="#favorites" styleClass="nav-button"/>
   <Button fx:id="messagesButton" text="Messages" onAction="#conversations" styleClass="nav-button"/>
   <Button fx:id="adminButton" text="Admin" onAction="#admin" styleClass="nav-button"/>
   <Separator orientation="VERTICAL"/>
   <Label fx:id="userLabel" styleClass="user-label"/>
   <Button fx:id="loginButton" text="Sign in" onAction="#login" styleClass="secondary-button"/>
   <Button fx:id="logoutButton" text="Log out" onAction="#logout" styleClass="ghost-button"/>
  </HBox>
  <VBox spacing="6" styleClass="search-hero">
   <Label text="Find something worth keeping" styleClass="search-title"/>
   <Label text="Quality second-hand items from people nearby." styleClass="search-subtitle"/>
   <HBox spacing="8" styleClass="filter-bar">
    <TextField fx:id="keywordField" promptText="Search listings" HBox.hgrow="ALWAYS" onAction="#search"/>
    <ComboBox fx:id="categoryBox" prefWidth="170"/><ComboBox fx:id="cityBox" prefWidth="135"/>
    <TextField fx:id="minPriceField" promptText="Min price" prefWidth="115"/>
    <TextField fx:id="maxPriceField" promptText="Max price" prefWidth="115"/>
    <ComboBox fx:id="conditionBox" prefWidth="140"/><ComboBox fx:id="sortBox" prefWidth="130"/>
    <Button text="Search" onAction="#search" styleClass="accent-button"/>
   </HBox>
  </VBox>
 </VBox></top>
 <center><ScrollPane fitToWidth="true"><VBox spacing="14" styleClass="page-content">
  <HBox alignment="CENTER_LEFT" styleClass="result-toolbar"><Label text="Latest listings" styleClass="section-title"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="resultLabel" styleClass="muted"/></HBox>
  <TilePane fx:id="adsPane" hgap="16" vgap="16" prefColumns="3"/>
 </VBox></ScrollPane></center>
</BorderPane>
