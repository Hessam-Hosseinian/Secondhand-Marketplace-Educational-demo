<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.MyAdsController">
 <top><HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar"><padding><Insets top="14" right="28" bottom="14" left="28"/></padding><Button text="← Marketplace" onAction="#back" styleClass="ghost-button"/><Region HBox.hgrow="ALWAYS"/><Button text="+ Create ad" onAction="#create" styleClass="primary-button"/></HBox></top>
 <center><ScrollPane fitToWidth="true"><VBox spacing="16"><padding><Insets top="28" right="34" bottom="40" left="34"/></padding><HBox><VBox><Label text="My advertisements" styleClass="page-title"/><Label text="Manage listings and follow their review status." styleClass="muted"/></VBox><Region HBox.hgrow="ALWAYS"/><Label fx:id="countLabel" styleClass="status-chip"/></HBox><VBox fx:id="listBox" spacing="12"/></VBox></ScrollPane></center>
</BorderPane>
