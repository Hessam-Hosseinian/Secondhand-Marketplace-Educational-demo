<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.MyAdsController" styleClass="page">
 <top><HBox alignment="CENTER_LEFT" spacing="10" styleClass="app-header"><Button text="Back" onAction="#back" styleClass="ghost-button"/><Label text="My listings" styleClass="wordmark"/><Region HBox.hgrow="ALWAYS"/><Button text="Create listing" onAction="#create" styleClass="primary-button"/></HBox></top>
 <center><ScrollPane fitToWidth="true"><VBox spacing="16" styleClass="page-content"><HBox><VBox spacing="4"><Label text="Manage your listings" styleClass="page-title"/><Label text="Track review status, edit details, or mark an item as sold." styleClass="muted"/></VBox><Region HBox.hgrow="ALWAYS"/><Label fx:id="countLabel" styleClass="status-chip"/></HBox><VBox fx:id="listBox" spacing="10"/></VBox></ScrollPane></center>
</BorderPane>
