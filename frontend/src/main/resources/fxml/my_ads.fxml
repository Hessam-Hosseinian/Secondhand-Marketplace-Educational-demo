<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.MyAdsController" styleClass="page">
 <top><HBox alignment="CENTER_LEFT" spacing="10" styleClass="app-header"><Button text="←  Marketplace" onAction="#back" styleClass="ghost-button"/><Region HBox.hgrow="ALWAYS"/><HBox alignment="CENTER_LEFT" spacing="8"><Label text="R" styleClass="brand-mark-small"/><HBox alignment="CENTER_LEFT" spacing="0"><Label text="Re:Market" styleClass="wordmark"/><Label text="." styleClass="wordmark-dot"/></HBox></HBox><Region HBox.hgrow="ALWAYS"/><Button text="＋  Create listing" onAction="#create" styleClass="primary-button"/></HBox></top>
 <center><StackPane>
  <ScrollPane fx:id="listingsContent" fitToWidth="true"><VBox alignment="TOP_CENTER" spacing="18" styleClass="my-listings-content">
   <HBox maxWidth="1080" alignment="CENTER_LEFT"><VBox spacing="4"><Label text="Your selling dashboard" styleClass="listing-page-title"/><Label text="Track every listing from review to sale, and quickly fix anything that needs attention." styleClass="muted"/></VBox><Region HBox.hgrow="ALWAYS"/><Button fx:id="refreshButton" text="↻  Refresh" onAction="#refresh" styleClass="secondary-button"/></HBox>
   <HBox maxWidth="1080" spacing="11"><VBox maxWidth="Infinity" HBox.hgrow="ALWAYS" spacing="3" styleClass="seller-stat-card"><Label text="All listings" styleClass="admin-stat-title"/><Label fx:id="allCountLabel" text="—" styleClass="seller-stat-value"/></VBox><VBox maxWidth="Infinity" HBox.hgrow="ALWAYS" spacing="3" styleClass="seller-stat-card, active-seller-stat"><Label text="Live" styleClass="admin-stat-title"/><Label fx:id="activeCountLabel" text="—" styleClass="seller-stat-value"/></VBox><VBox maxWidth="Infinity" HBox.hgrow="ALWAYS" spacing="3" styleClass="seller-stat-card"><Label text="In review" styleClass="admin-stat-title"/><Label fx:id="pendingCountLabel" text="—" styleClass="seller-stat-value"/></VBox><VBox maxWidth="Infinity" HBox.hgrow="ALWAYS" spacing="3" styleClass="seller-stat-card, attention-seller-stat"><Label text="Needs changes" styleClass="admin-stat-title"/><Label fx:id="attentionCountLabel" text="—" styleClass="seller-stat-value"/></VBox></HBox>
   <HBox maxWidth="1080" alignment="CENTER_LEFT" spacing="10" styleClass="my-listings-toolbar"><VBox spacing="2"><Label text="Listings" styleClass="section-title"/><Label text="Manage status and item availability." styleClass="admin-row-meta"/></VBox><Region HBox.hgrow="ALWAYS"/><Label text="Show" styleClass="field-label"/><ComboBox fx:id="statusFilter" onAction="#applyFilter" prefWidth="165"/><Label fx:id="countLabel" styleClass="result-count"/></HBox>
   <VBox fx:id="listBox" maxWidth="1080" spacing="10"/>
   <VBox fx:id="listingsEmpty" maxWidth="1080" alignment="CENTER" spacing="9" visible="false" managed="false" styleClass="admin-empty-state"><Label text="◇" styleClass="admin-empty-icon"/><Label text="No listings in this view" styleClass="admin-empty-title"/><Label text="Choose another status or create a new listing." styleClass="admin-row-meta"/><Button text="Create a listing" onAction="#create" styleClass="primary-button"/></VBox>
  </VBox></ScrollPane>
  <VBox fx:id="listingsLoading" alignment="CENTER" spacing="10" styleClass="form-loading"><ProgressIndicator prefWidth="42" prefHeight="42"/><Label text="Loading your listings…" styleClass="muted"/></VBox>
 </StackPane></center>
</BorderPane>
