<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.RatingDialogController" spacing="13" prefWidth="430" styleClass="dialog-page">
 <padding><Insets top="28" right="30" bottom="28" left="30"/></padding><Label text="How was the seller?" styleClass="page-title"/><Label text="Your feedback helps the community buy with confidence." wrapText="true" styleClass="muted"/>
 <Label text="Rating" styleClass="field-label"/><ComboBox fx:id="ratingBox" maxWidth="Infinity"/><Label text="Comment" styleClass="field-label"/><TextArea fx:id="commentArea" promptText="Share a short, helpful note…" prefRowCount="4" wrapText="true"/>
 <HBox alignment="CENTER_RIGHT" spacing="10"><Button text="Cancel" onAction="#cancel" styleClass="secondary-button"/><Button text="Submit rating" onAction="#submit" styleClass="primary-button"/></HBox>
</VBox>
