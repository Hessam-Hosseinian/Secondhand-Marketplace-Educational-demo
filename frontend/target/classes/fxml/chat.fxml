<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.ChatController" styleClass="page">
 <top><HBox alignment="CENTER_LEFT" spacing="10" styleClass="app-header"><Button text="Back to messages" onAction="#back" styleClass="ghost-button"/><Region HBox.hgrow="ALWAYS"/><Label text="Conversation" styleClass="wordmark"/><Button text="Refresh" onAction="#refresh" styleClass="secondary-button"/></HBox></top>
 <center><ScrollPane fx:id="scrollPane" fitToWidth="true"><VBox fx:id="messagesBox" spacing="14" styleClass="page-content"/></ScrollPane></center>
 <bottom><HBox spacing="10" styleClass="composer"><TextField fx:id="messageField" promptText="Write a message" onAction="#send" HBox.hgrow="ALWAYS"/><Button text="Send" onAction="#send" styleClass="primary-button"/></HBox></bottom>
</BorderPane>
