<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.ConversationsController">
 <top><HBox alignment="CENTER_LEFT" styleClass="topbar"><padding><Insets top="14" right="28" bottom="14" left="28"/></padding><Button text="← Marketplace" onAction="#back" styleClass="ghost-button"/><Region HBox.hgrow="ALWAYS"/><Label text="Messages" styleClass="brand"/></HBox></top>
 <center><ScrollPane fitToWidth="true"><VBox spacing="16"><padding><Insets top="30" right="34" bottom="40" left="34"/></padding><Label text="Conversations" styleClass="page-title"/><Label text="Your recent conversations with buyers and sellers." styleClass="muted"/><Label fx:id="emptyLabel" text="No conversations yet." styleClass="empty-state"/><VBox fx:id="listBox" spacing="12"/></VBox></ScrollPane></center>
</BorderPane>
