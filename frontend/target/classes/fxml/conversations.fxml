<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.ConversationsController" styleClass="page">
 <top><HBox alignment="CENTER_LEFT" styleClass="app-header"><Button text="Back" onAction="#back" styleClass="ghost-button"/><Region HBox.hgrow="ALWAYS"/><Label text="Messages" styleClass="wordmark"/></HBox></top>
 <center><ScrollPane fitToWidth="true"><VBox spacing="14" styleClass="page-content"><Label text="Your conversations" styleClass="page-title"/><Label text="Questions and offers from buyers and sellers." styleClass="muted"/><Label fx:id="emptyLabel" text="No conversations yet." styleClass="empty-state"/><VBox fx:id="listBox" spacing="10"/></VBox></ScrollPane></center>
</BorderPane>
