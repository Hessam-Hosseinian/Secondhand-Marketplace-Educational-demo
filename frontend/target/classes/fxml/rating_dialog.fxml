<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.RatingDialogController" spacing="12" prefWidth="440" styleClass="dialog-page">
 <Label text="Rate this seller" styleClass="page-title"/><Label text="Your feedback helps other buyers make confident decisions." wrapText="true" styleClass="muted"/>
 <Label text="Rating" styleClass="field-label"/><ComboBox fx:id="ratingBox" maxWidth="Infinity"/><Label text="Comment (optional)" styleClass="field-label"/><TextArea fx:id="commentArea" promptText="Share a helpful note" prefRowCount="4" wrapText="true"/>
 <HBox alignment="CENTER_RIGHT" spacing="10"><Button text="Cancel" onAction="#cancel" styleClass="secondary-button"/><Button text="Submit rating" onAction="#submit" styleClass="primary-button"/></HBox>
</VBox>
