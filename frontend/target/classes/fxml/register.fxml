<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.secondhand.client.controller.RegisterController" styleClass="auth-background">
 <VBox prefWidth="560" maxWidth="560" prefHeight="540" maxHeight="540"  spacing="11" styleClass="surface">
  <Label text="Create your account" styleClass="auth-title"/>
  <Label text="One account for buying, selling, and messaging." styleClass="muted"/>
  <Label text="Full name" styleClass="field-label"/><TextField fx:id="fullNameField" promptText="Your full name"/>
  <Label text="Username" styleClass="field-label"/><TextField fx:id="usernameField" promptText="Choose a unique username"/>
  <HBox spacing="10"><VBox spacing="6" HBox.hgrow="ALWAYS"><Label text="Email" styleClass="field-label"/><TextField fx:id="emailField" promptText="you@example.com"/></VBox><VBox spacing="6" HBox.hgrow="ALWAYS"><Label text="Phone" styleClass="field-label"/><TextField fx:id="phoneField" promptText="09xxxxxxxxx"/></VBox></HBox>
  <Label text="Password" styleClass="field-label"/><PasswordField fx:id="passwordField" promptText="At least 6 characters"/>
  <Label fx:id="errorLabel" styleClass="error-text" wrapText="true"/>
  <Button text="Create account" onAction="#submit" maxWidth="Infinity" styleClass="primary-button"/>
  <Button text="Back to sign in" onAction="#back" maxWidth="Infinity" styleClass="ghost-button"/>
 </VBox>
</StackPane>
